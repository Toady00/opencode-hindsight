{
  "name": "@toady00/opencode-hindsight",
  "version": "0.1.1",
  "description": "Per-agent Hindsight memory plugin for opencode",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
