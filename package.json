    "CHANGELOG.md",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "opencode",
    "opencode-plugin",
    "hindsight",
    "memory",
    "ai-agent",
    "agent-memory",
    "vectorize"
  ],
  "author": "Brandon Dennis",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Toady00/opencode-hindsight.git"
  },
  "bugs": {
    "url": "https://github.com/Toady00/opencode-hindsight/issues"
  },
  "homepage": "https://github.com/Toady00/opencode-hindsight#readme",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run"
  },
  "dependencies": {
    "@vectorize-io/hindsight-client": "^0.6.0"
  },
  "peerDependencies": {
    "@opencode-ai/plugin": ">=1.14.41"
  },
  "devDependencies": {
    "@opencode-ai/plugin": "^1.14.41",
